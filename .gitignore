# General
yarn-error.log
node_modules
.DS_STORE
.vscode
.idea
.worktrees/

# Config files
.env

# Avoid ignoring gitkeep
!/**/.gitkeep

# Cursor rules files
.cursorrules*

# Ignore generated markdown notes/logs (keeps stray AI/agent scratch notes out of
# the repo). Anything meant to be REAL documentation must be un-ignored below, or
# git will silently drop it — including a brand-new page under docs/, which is a
# trap: the existing docs/ pages only survive because they were committed before
# this rule existed, and gitignore does not affect already-tracked files.
*.md
!README.md
!CLAUDE.md
!SECURITY.md
!PROGRESS.md
!FIXES.md
!docs/**/*.md

# Keep local documentation drafts out of commits.
docs/*
