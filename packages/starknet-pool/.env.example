# Starknet destination pool deployment — read by deploy/deploy-starknet.sh.
# Copy to .env and fill. Never commit .env.
#
# No private key lives here: signing uses the sncast account store
# (~/.starknet_accounts/...). This file only names which account to use.

# sncast account name. List them with: sncast account list
SN_ACCOUNT=sn2

# Starknet Sepolia RPC. Two hard requirements:
#   1. A STARKNET JSON-RPC endpoint — an EVM URL (optimism-sepolia, base-sepolia, ...) will NOT
#      work; sncast speaks the Starknet API, not Ethereum's.
#   2. JSON-RPC spec v0.10.x — sncast 0.57 refuses older nodes:
#      "uses incompatible version 0.8.1. Expected version: 0.10.0". Infura currently serves
#      0.8.1, so it is NOT usable here.
# A chainId curl is not a sufficient check (it succeeds on any spec version); verify with sncast.
SN_RPC=https://api.zan.top/public/starknet-sepolia/rpc/v0_10

# The L1 pool this Cairo pool accepts notes from. IMMUTABLE — set in the constructor.
#
# `receive_note` asserts `from_address == l1_pool`. Point this at anything other than the
# canonical L1 PrivacyPool and the bridge is a trap: StarkGate still delivers the ETH, but the
# note message is rejected, so the value lands with no note that can ever claim it. This is
# exactly why the pool gets REDEPLOYED rather than reconfigured.
L1_POOL_ADDRESS=0x98657a6690bd0b4b4b224d5c44d100a6fb9eb3a2

# The L2 ERC20 the pool holds (StarkGate-bridged ETH on Starknet Sepolia), as a felt.
SN_ASSET_ADDRESS=0x049d36570d4e46f48e99674bd3fcc84644ddd6b96f7c741b1562b82f9e004dc7

# Optional. Maximum relay fee in basis points (script default: 100).
SN_MAX_RELAY_FEE_BPS=100

# Optional. Set to 1 to also run a free on-chain groth16 verify with the spike fixture.
SN_VERIFY_FIXTURE=0
