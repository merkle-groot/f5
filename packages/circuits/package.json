{
  "name": "@privacy-pool-core/circuits",
  "version": "1.0.0",
  "description": "Circom circuits for the Privacy Pool protocol",
  "repository": "https://github.com/defi-wonderland/privacy-pool-core",
  "license": "Apache-2.0",
  "author": "Wonderland",
  "scripts": {
    "compile": "npx ts-node ./src/index.ts",
    "test": "npx mocha",
    "test:merkle": "npx mocha tests/lean-imt.test.ts",
    "test:stealth": "npx mocha tests/stealth.test.ts",
    "test:commitment": "npx mocha tests/commitment.test.ts tests/commitmentL2.test.ts",
    "test:withdraw": "npx mocha tests/withdrawL1.test.ts tests/withdrawL2.test.ts",
    "circomspect": "circomspect -L ../../node_modules/circomlib/circuits/comparators.circom -L ../../node_modules/circomlib/circuits/mux1.circom -L ../../node_modules/circomlib/circuits/poseidon.circom ./circuits/*",
    "info:withdrawL1": "npx circomkit info withdrawL1",
    "info:withdrawL2": "npx circomkit info withdrawL2",
    "info:commitmentL1": "npx circomkit info commitmentL1",
    "setup:ptau": "npx circomkit ptau withdrawL1",
    "setup:all": "yarn setup:ptau && yarn setup:withdrawL1 && yarn setup:withdrawL2 && yarn setup:merkle && yarn setup:commitmentL1",
    "setup:withdrawL1": "npx circomkit setup withdrawL1 ptau/powersOfTau28_hez_final_16.ptau",
    "setup:withdrawL2": "npx circomkit setup withdrawL2 ptau/powersOfTau28_hez_final_16.ptau",
    "setup:commitmentL1": "npx circomkit setup commitmentL1 ptau/powersOfTau28_hez_final_16.ptau",
    "setup:merkle": "npx circomkit setup merkleTree ptau/powersOfTau28_hez_final_16.ptau",
    "present": "sh ./scripts/present.sh",
    "prove:withdrawL1": "npx circomkit prove withdrawL1 default",
    "prove:commitmentL1": "npx circomkit prove commitmentL1 default",
    "verify:withdrawL1": "npx circomkit verify withdrawL1 default",
    "verify:commitmentL1": "npx circomkit verify commitmentL1 default",
    "gencontract:withdraw": "sh ./scripts/gen-verifier.sh withdrawL1 WithdrawalVerifier",
    "gencontract:withdrawL2": "sh ./scripts/gen-verifier.sh withdrawL2 L2WithdrawalVerifier",
    "gencontract:commitment": "sh ./scripts/gen-verifier.sh commitmentL1 CommitmentVerifier"
  },
  "dependencies": {
    "@zk-kit/lean-imt": "2.2.2",
    "chai": "5.1.2",
    "circomkit": "0.3.2",
    "circomlib": "2.0.5",
    "maci-circuits": "2.5.0",
    "maci-crypto": "2.5.0",
    "snarkjs": "0.7.5",
    "viem": "2.21.57"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "20.3.1",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.1",
    "typescript": "5.5.4"
  }
}
