# Relayer process configuration. Copy to .env and fill. Never commit .env.
#
# NOTE: most of the relayer's configuration is NOT here — chains, RPCs, entrypoint, ASP pools,
# supported assets and the signer key live in the JSON file that CONFIG_PATH points at
# (e.g. config.sepolia.json). This file only holds process-level knobs and secret overrides.

# --- Required ---
# Which JSON config to load. Without it the relayer looks for ./config.json and exits if missing.
CONFIG_PATH=./config.sepolia.json

# --- Server ---
PORT=8788
HOST=0.0.0.0

# --- Testnet ASP ---
# Mirrors every configured pool's deposit labels into the Entrypoint's ASP root, and serves
# /relayer/asp/proof/:label. Without this the ASP endpoints 404 and withdrawals cannot prove
# association. The signer must hold the ASP_POSTMAN role AND have gas, or the root never publishes
# (the proof still returns, but the pool then rejects the withdrawal with IncorrectASPRoot).
TESTNET_ASP_MODE=true
# How often to re-scan for new labels (ms).
TESTNET_ASP_POLL_MS=10000
# TESTNET_ASP_IPFS_CID=testnet-asp-root-all-labels-placeholder

# --- Secret overrides (optional) ---
# Take precedence over chains[].signer_private_key and defaults.signer_private_key in the JSON
# config. Use these to keep the key out of a committed-ish config file.
# RELAYER_PRIVATE_KEY=0x...
# RELAYER_SIGNER_PRIVATE_KEY=0x...
# RELAYER_FEE_RECEIVER_ADDRESS=0x...

# --- Indexing ---
# Blocks per eth_getLogs window. Public RPCs cap the range (Infura rejects >10000 with
# "range N exceeds limit of 10000"). Lower this if your provider is stricter.
# LOG_CHUNK_BLOCKS=9000

# --- Misc ---
# NODE_ENV=production
# RELAYER_HOST=testnet-relayer.privacypools.com
