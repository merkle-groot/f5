# The app server holds NO private keys and signs NO transactions. Signing keys live
# in packages/relayer/.env; this process indexes and proxies. See RELAYER_API_URL.

PORT=8787
CHAIN_ID=11155111
CHAIN_NAME=Sepolia
PUBLIC_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
POOL_ADDRESS=0x8d508e422ed2bc102ba364875d2d83c172dc2288
ASSET_ADDRESS=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE
ASSET_SYMBOL=ETH
ASSET_DECIMALS=18
MIN_DEPOSIT_WEI=0
VETTING_FEE_BPS=0
DEPLOYMENT_BLOCK=11257510
POOL_SCOPE=12705350489854253318627594584603522235053999919293907099038827448300325643010
ASP_API_URL=http://localhost:8790
TESTNET_ASP_MODE=true
# Block-explorer origin for the transactions a user signs or relays. Optional:
# unset means the UI shows the hash without a link.
EXPLORER_URL=https://sepolia.etherscan.io
# EVM L2 destinations. Comma-separated keys; each needs a matching <KEY>_* block.
# The client scans and offers exactly the chains listed here. Add "base" once filled.
# Each key here needs a matching `destinations` entry in the relayer's config.json
# under the SAME key, or writes to it will 404.
L2_EVM_CHAINS=op

# The app server scans for backed pending notes and asks the relayer to activate them.
# The relayer never polls. Every destination uses the same 15-second active cadence.
L2_AUTO_ACTIVATE=true
L2_SCAN_POLL_MS=15000

# --- OP Sepolia ---
OP_CHAIN_ID=11155420
OP_CHAIN_NAME=OP Sepolia
OP_RPC_URL=https://optimism-sepolia.infura.io/v3/your_infura_project_id
OP_POOL_ADDRESS=0xfA1B3a3bAB430c19d6c83d8f3F1619bDdCbddcdd
OP_DEPLOYMENT_BLOCK=46208090
OP_BLOCK_TIME_MS=2000
OP_EXPLORER_URL=https://sepolia-optimism.etherscan.io

# --- Base Sepolia (fill, then add "base" to L2_EVM_CHAINS above) ---
BASE_CHAIN_ID=84532
BASE_CHAIN_NAME=Base Sepolia
BASE_RPC_URL=https://base-sepolia.infura.io/v3/your_infura_project_id
BASE_POOL_ADDRESS=
BASE_DEPLOYMENT_BLOCK=
BASE_BLOCK_TIME_MS=2000
BASE_EXPLORER_URL=https://sepolia.basescan.org
STARKNET_CHAIN_ID=393402133025997798000961
STARKNET_CHAIN_NAME=Starknet Sepolia
# Pool/asset from packages/starknet-pool/deployments/starknet-<chainId>.json; network infra
# (Core, StarkGate, chain id) from docs/DEPLOYMENT.md §8.
STARKNET_RPC_URL=https://your-starknet-sepolia-rpc.example
STARKNET_POOL_ADDRESS=0x07b336e836269575c4f4fe3fe69e41eff7d918872e8ef2f3cde57abaa035621c
STARKNET_ASSET_ADDRESS=0x049d36570d4e46f48e99674bd3fcc84644ddd6b96f7c741b1562b82f9e004dc7
STARKNET_BLOCK_TIME_MS=30000
STARKNET_EXPLORER_URL=https://sepolia.voyager.online
# The relayer destination key the Starknet routes forward to.
STARKNET_DESTINATION_KEY=starknet
RELAYER_NAME=F5
RELAY_FEE_BPS=30
# REQUIRED. Every write path goes here; without it the app can only read.
RELAYER_API_URL=http://localhost:8788
RELAYER_DETAILS_TTL_MS=30000
ENTRYPOINT_ADDRESS=0x157b0c29d676bbbfd3d8a3fb8c4979a5b5eaa793

# --- RPC tuning ---
# Max concurrent RPC calls per chain. SHARED WITH THE RELAYER: packages/relayer reads
# the same variable name, and both processes hit the same endpoints, so set it to the
# same number in both .env files. Raise it only if your provider's per-minute quota
# has room; 1 is the safe default for a free tier.
# (Was RPC_LOG_CONCURRENCY here — still honoured, but rename it: the old name tuned
# only this process and left the relayer at 1.)
# RPC_CONCURRENCY=1
# How long a chain-head read is cached and coalesced across callers.
# RPC_HEAD_TTL_MS=2500
# Blocks per eth_getLogs request. Lower this if your provider caps the range —
# Alchemy's free tier allows only 10, against the 9000 default.
# LOG_CHUNK_BLOCKS=9000

# --- Activation scan pacing (the main RPC-cost lever) ---
# The scanner runs fast only when there is something to watch: a destination with
# pending notes, or one inside an L2_ACTIVE_WINDOW_MS nudge. Otherwise it drops to
# L2_IDLE_POLL_MS. An always-fast scanner spends its whole budget proving nothing
# happened — measured at ~10x the requests of the adaptive one on an idle pool.
# How slowly to scan a destination with nothing pending. Raise it to cut RPC spend;
# the cost is up to this much extra latency before a landed note is noticed, on top
# of bridge settlement that already takes minutes.
L2_IDLE_POLL_MS=60000
# Fast-poll window after an accepted L1 relay. 0 = off (default).
# The app server does not parse relay bodies, so this wakes EVERY destination; with
# several destinations it costs far more in RPC than the idle polling it replaces,
# to save at most one L2_IDLE_POLL_MS of latency. Price it before enabling.
L2_ACTIVE_WINDOW_MS=0
